{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ],
  "env": {
    "JWT_SECRET": "@tarot_jwt_secret",
    "OPENAI_API_KEY": "@tarot_openai_key"
  }
}
