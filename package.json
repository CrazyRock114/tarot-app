{
  "name": "tarot-app",
  "version": "1.0.0",
  "description": "AI 塔罗占卜平台 - Vercel 部署版",
  "scripts": {
    "build": "cd client && npm install && npm run build && cp -r dist ../dist",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@vercel/node": "^3.2.24",
    "concurrently": "^8.2.2",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": "20.x"
  }
}
