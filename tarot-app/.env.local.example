# 本地开发环境变量配置
# 复制此文件为 .env.local 并填入实际值

# DeepSeek API Key (必填)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# MongoDB 连接字符串 (必填)
# 本地开发可以使用 MongoDB Compass 或本地安装的 MongoDB
# 格式: mongodb://localhost:27017/tarot
# 或使用 MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/tarot
MONGODB_URI=mongodb://localhost:27017/tarot

# JWT 密钥 (必填)
JWT_SECRET=your-super-secret-jwt-key-for-local-development

# 站点基础 URL (本地开发)
BASE_URL=http://localhost:3000

# 可选: Node 环境
NODE_ENV=development

# 可选: 服务器端口
PORT=5000
