{
  "name": "ai-tarot",
  "version": "1.0.0",
  "description": "AI 塔罗占卜平台 - Vercel 原生部署版",
  "type": "module",
  "scripts": {
    "build": "cd client && npm install && npm run build && cp -r dist ../dist",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "tsx api/server.ts",
    "dev:server:legacy": "cd server && npm run dev",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "msedge-tts": "^2.0.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@vercel/node": "^3.2.24",
    "concurrently": "^8.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": "20.x"
  }
}
