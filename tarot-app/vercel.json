{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "routes": [
    { "src": "/api/debug", "dest": "/api/debug" },
    { "src": "/api/health", "dest": "/api/index" },
    { "src": "/api/tarot/cards", "dest": "/api/index" },
    { "src": "/api/tarot/reading", "dest": "/api/index" },
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
