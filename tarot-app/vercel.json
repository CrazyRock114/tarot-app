{
  "version": 2,
  "installCommand": "npm install && cd client && npm install",
  "buildCommand": "cd client && npm run build && cp -r dist ../dist",
  "outputDirectory": "dist",
  "framework": null,
  "routes": [
    { "src": "/api/health", "dest": "/api/index" },
    { "src": "/api/tarot/cards", "dest": "/api/index" },
    { "src": "/api/tarot/reading", "dest": "/api/index" },
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/dist/index.html" }
  ]
}
